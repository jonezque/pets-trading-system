# --- Server ---
PORT=3000

# --- Database ---
# Local docker-compose uses the 'db' service hostname.
DATABASE_URL=postgres://pets:pets@db:5432/pets

# --- Game configuration ---
# Fixed starting cash per trader (sized to buy ~5-8 new pets).
INITIAL_CASH=500
# Units of new supply created per breed.
SUPPLY_PER_BREED=3
# How often the valuation engine ticks (ms).
VALUATION_INTERVAL_MS=60000
# Years of age added to each pet per valuation tick (accelerated for demos).
AGE_PER_TICK=1
# Max +/- fluctuation applied to health & desirability per tick (fraction).
FLUCTUATION=0.05
# How often the browser polls for fresh fragments (seconds, used in HTMX).
POLL_INTERVAL=3
